# GitHub to Confluence Sync - Environment Configuration
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: Never commit .env to version control!

# Your GitHub Personal Access Token
# Get it from: https://github.com/settings/tokens
GITHUB_TOKEN="your_github_token_here"

# Your Jira Confluence API Token
# Get it from: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_TOKEN="your_confluence_token_here"

# Your Confluence base URL (no trailing slash)
# Example: https://mycompany.atlassian.net
CONFLUENCE_BASE_URL="https://your-domain.atlassian.net"

# Your Confluence Space Key
# Find this in Confluence: Space Settings → Details
CONFLUENCE_SPACE_KEY="SPACEKEY"
